{
  "name": "bot-de-pure",
  "version": "1.0.0",
  "description": "Bot de puré es un bot de entretenimiento, búsqueda de imágenes y utilidades generales varias. Utiliza comandos tradicionales con adiciones inspiradas en terminales como <code>--flags</code>.<br>\r Como personaje, es una robot \"mujer\". Es torpe y agresiva en algunos casos, pero parece tener espíritu.",
  "type": "module",
  "engines": {
    "bun": "^1.3.5"
  },
  "packageManager": "bun@1.3.5",
  "main": "main.js",
  "scripts": {
    "dev": "bun --env-file=.env ./src/main.ts",
    "prod": "bun --env-file=.env.production ./src/main.ts",
    "lint": "bunx biome lint",
    "lint:fix": "bunx biome lint --write && bunx biome format --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PapitaConPure/bot-de-pure.git"
  },
  "keywords": [],
  "author": "PapitaConPure",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PapitaConPure/bot-de-pure/issues"
  },
  "homepage": "https://github.com/PapitaConPure/bot-de-pure#readme",
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@date-fns/utc": "^2.1.1",
    "@discord-player/extractor": "^7.2.0",
    "@distube/ytdl-core": "^4.16.12",
    "@napi-rs/canvas": "^0.1.97",
    "chalk": "^4.1.2",
    "date-fns": "^4.1.0",
    "discord-player": "^7.2.0",
    "discord-player-googlevideo": "^0.2.5",
    "discord-player-soundcloud": "^1.0.7",
    "discord.js": "^14.26.2",
    "groq-sdk": "^0.29.0",
    "minimist": "^1.2.8",
    "mongoose": "^6.13.9",
    "mongoose-int32": "^0.6.0",
    "node-catbox": "^3.4.0",
    "object-sizeof": "^2.6.5",
    "sagiri": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/bun": "latest",
    "@types/minimist": "^1.2.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
