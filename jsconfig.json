{
    "compilerOptions": {
        "target": "es2024",
        "module": "es2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "checkJs": true,
		"removeComments": false,
        "resolveJsonModule": true,
        "paths": {
            "types": ["./src/types/util.ts"],
            "types/*": ["./src/types/*"],
            "@/*": [
                "./src/*"
            ]
        },
        "strict": false,
        "strictBindCallApply": true,
        "strictNullChecks": true,
        "skipLibCheck": true
    },
    "exclude": [
        "node_modules",
        "PS Docs",
        "src/systems/ps/v1.0",
        "src/systems/ps/v1.1"
    ],
}
