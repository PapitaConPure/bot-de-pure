{
    "compilerOptions": {
        "target": "es2024",
        "module": "es2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "checkJs": true,
		"removeComments": false,
        "resolveJsonModule": true,
        "paths": {
            "types": ["./src/types/util.ts"],
            "types/*": ["./src/types/*"],
            "@/*": [
                "./src/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "PS Docs"
    ],
}
